# ============================================
# 知客 KnowClient — 环境变量配置
# 复制此文件为 .env.local 并填入真实值
# ============================================

# === 数据库（MySQL）===
# 本地开发: localhost / 生产: MySQL 托管地址
DB_HOST="localhost"
DB_PORT="3306"
DB_USER="root"
DB_PASSWORD="your_mysql_password"
DB_NAME="knowclient"

# === 数据库连接池（可选，以下为默认值）===
DB_POOL_MIN="2"
DB_POOL_MAX="10"

# === AI 模型（DeepSeek）===
# 在 https://platform.deepseek.com 注册获取 API Key
DEEPSEEK_API_KEY="sk-your-deepseek-api-key"

# === NextAuth 认证 ===
# 生成方法: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-random-64-char-string"
# 生产环境改为实际域名
AUTH_URL="http://localhost:3000"

# === 邮箱服务（验证码登录）===
# 可选：使用 Resend、SendGrid 或 SMTP
# 如果不配置，开发环境会打印验证码到控制台
EMAIL_SERVER=""
EMAIL_FROM="知客 <noreply@knowclient.app>"

# === Vercel Blob（文件上传，可选）===
# Vercel 部署时自动配置，本地开发不需要
# BLOB_READ_WRITE_TOKEN=""
